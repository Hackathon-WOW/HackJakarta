# ── Production env for docker-compose.prod.yml (copy to .env on the Droplet) ──

# Public URL of the app (used for the frontend build + CORS).
#  - With a domain:  https://grow.example.com
#  - With only an IP: http://203.0.113.10
PUBLIC_URL=https://grow.example.com

# Caddy TLS domain.
#  - hostname  => automatic HTTPS (Let's Encrypt). Must point DNS A record to the Droplet.
#  - ":80"     => plain HTTP (use when you only have an IP, no domain)
DOMAIN=grow.example.com

# Database
POSTGRES_USER=grow
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=grow

# Auth — MUST be a long random string in production
JWT_SECRET=change-me-to-a-long-random-secret

# AI provider (free). Leave blank to use the built-in data-driven fallback.
#  Groq:   https://api.groq.com/openai/v1   model: llama-3.3-70b-versatile
#  Gemini: https://generativelanguage.googleapis.com/v1beta/openai   model: gemini-2.0-flash
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile
