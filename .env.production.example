# ── Production env for docker-compose.prod.yml (place at DEPLOY_PATH/.env on the Droplet) ──
# Images are pulled from GHCR (built in CI). The Droplet does not build.

# Public URL of the app (used for CORS on the backend).
#  NOTE: also set this as a GitHub repo VARIABLE named PUBLIC_URL — it is baked into the
#  frontend image at build time in CI.
PUBLIC_URL=https://grow.example.com

# Caddy TLS domain:
#   hostname  => automatic HTTPS (DNS A record must point to the Droplet)
#   ":80"     => plain HTTP (IP only)
DOMAIN=grow.example.com

# Caddy published ports — change if the Droplet already uses 80/443 for another app.
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# Database
POSTGRES_USER=grow
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=grow

# Auth — long random string
JWT_SECRET=change-me-to-a-long-random-secret

# AI provider (free). Blank => built-in data-driven fallback.
AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=
AI_MODEL=llama-3.3-70b-versatile

# Optional image overrides (defaults to ghcr.io/hackathon-wow/grow-*:latest)
# BACKEND_IMAGE=ghcr.io/hackathon-wow/grow-backend:latest
# FRONTEND_IMAGE=ghcr.io/hackathon-wow/grow-frontend:latest
